.claude-config

# Claudeman runtime binaries + persistent caches (pip, Playwright browsers, etc.)
.claude/claudeman/bin/
.claude/claudeman/cache/

# Generated artifacts
out/
work/
.showtape-work/

# Python build / dist
__pycache__/
*.egg-info/
*.pyc
build/
dist/

# Voice models (~80 MB each — fetch via `showtape fetch-voice`)
voices/*.onnx
voices/*.onnx.json
