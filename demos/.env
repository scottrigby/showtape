# showtape .env — loaded automatically when the YAML file being rendered
# lives in the same directory as this file.
#
# For your own demos:
#   1. Copy this file next to your YAML (it must be a sibling, not a parent dir).
#   2. Fill in real values for any ${VAR_NAME} placeholders in your YAML.
#   3. Add .env to your .gitignore — keep credentials out of git.
#      The committed YAML with ${VAR_NAME} placeholders is safe to share.
#
# Syntax:
#   KEY=value                  no quoting required for values with spaces
#   KEY="value"                double quotes (contents taken literally, no \n etc.)
#   KEY='value'                single quotes (same)
#   KEY=value  # comment       inline comments after whitespace are stripped
#
# The shell environment always takes precedence over .env values,
# so CI secrets ($DEMO_PROJECT set in CI) override local .env automatically.

DEMO_PROJECT=my-awesome-app
DEMO_ENVIRONMENT=production
DEMO_REGISTRY=ghcr.io/myorg
